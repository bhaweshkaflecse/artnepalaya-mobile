# API URL Configuration
# For Android Emulator: Use 10.0.2.2 which maps to host machine localhost
# This avoids Nginx proxy gateway errors during local development
EXPO_PUBLIC_API_URL=http://10.0.2.2:8080/api/v1

# For iOS Simulator or physical device on same network:
# EXPO_PUBLIC_API_URL=http://192.168.x.x:8080/api/v1

# For production:
# EXPO_PUBLIC_API_URL=https://api.artnepalaya.com/api/v1
